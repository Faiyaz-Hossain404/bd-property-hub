# =============================================================================
# BD Property Hub — environment template
# Copy to `.env` and fill in. `.env` is gitignored and MUST NOT be committed.
# Values here are placeholders/dev defaults only — no real secrets.
# =============================================================================

NODE_ENV=development

# --- Web (apps/web) — NEXT_PUBLIC_* values are exposed to the browser ---------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- API (apps/api) -----------------------------------------------------------
API_PORT=4000
API_GLOBAL_PREFIX=api
CORS_ORIGINS=http://localhost:3000

# directConnection=true is required to reach a single-node replica set from the host.
MONGODB_URI=mongodb://localhost:27017/bdph?replicaSet=rs0&directConnection=true
MONGODB_DB_NAME=bdph
REDIS_URL=redis://localhost:6379

# --- Auth: Clerk (ClerkAuthProvider) -----------------------------------------
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- Auth: first-party / manual (LocalAuthProvider) --------------------------
# Generate strong secrets for real environments (e.g. `openssl rand -hex 32`).
SESSION_SECRET=dev-only-session-secret-change-me
JWT_ACCESS_SECRET=dev-only-access-secret-change-me
JWT_REFRESH_SECRET=dev-only-refresh-secret-change-me
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
OTP_TTL=300

# --- Email (Resend) -----------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=BD Property Hub <no-reply@bdpropertyhub.test>

# --- Object storage ----------------------------------------------------------
# Listing photos use Cloudinary for now. Set CLOUDINARY_URL to enable photo
# uploads (until then the upload routes return 503). Copy the "API environment
# variable" from your Cloudinary dashboard:
#   CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=
# Cloudflare R2 remains the planned target for private documents (later).
STORAGE_PROVIDER=cloudinary
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET=bdph-public-media
R2_PRIVATE_BUCKET=bdph-private-docs
R2_PUBLIC_BASE_URL=

# --- Maps (MapLibre+OSM in dev; Google Maps at launch) -----------------------
MAPS_PROVIDER=maplibre
GOOGLE_MAPS_API_KEY=

# --- Real-time chat (apps/chat-gateway) --------------------------------------
CHAT_GATEWAY_PORT=4100

# --- Observability ------------------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
